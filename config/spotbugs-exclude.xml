<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>

    <!-- Spring configuration classes are instantiated by the framework, not by application code -->
    <Match>
        <Class name="~com\.silicaproxy\.config\..*"/>
        <Bug pattern="ST_WRITE_TO_STATIC_FROM_INSTANCE_METHOD"/>
    </Match>

    <!-- Entities and DTOs intentionally use public fields (Java records) -->
    <Match>
        <Class name="~com\.silicaproxy\.model\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- Passwords/tokens in config properties are read from the environment,
         not hardcoded — SpotBugs raises false positives on @Nullable String fields -->
    <Match>
        <Class name="com.silicaproxy.properties.SilicaProxyProperties"/>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>

    <!-- The PKCS12 KeyStore used for the MITM CA is intentionally unprotected by a
         password by default (the file itself is the security boundary) -->
    <Match>
        <Class name="com.silicaproxy.service.interception.SslMitmService"/>
        <Bug pattern="HARD_CODE_PASSWORD"/>
    </Match>

    <!-- SSLContext and KeyStore internal to SSL MITM are deliberately built without
         client trust store validation (the proxy trusts everything by design) -->
    <Match>
        <Class name="com.silicaproxy.service.interception.SslMitmService"/>
        <Bug pattern="WEAK_TRUST_MANAGER,SSL_CONTEXT"/>
    </Match>

    <!-- LoomProxyServer is an intentional MITM proxy: the ServerSocket listens in
         cleartext on loopback only (TLS encryption is handled by the upstream layer) -->
    <Match>
        <Class name="com.silicaproxy.service.interception.LoomProxyServer"/>
        <Bug pattern="UNENCRYPTED_SERVER_SOCKET,UNENCRYPTED_SOCKET"/>
    </Match>

    <!-- Spring components (config/controller/dao/service) store their dependencies via
         constructor injection (singleton beans) or infrastructure objects with a
         managed lifecycle (Proxy, read-only HttpHeaders, ObjectMapper). SpotBugs
         cannot distinguish these cases from genuine mutability leaks. -->
    <Match>
        <Class name="~com\.silicaproxy\.(config|controller|dao|service)\..*"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

</FindBugsFilter>
